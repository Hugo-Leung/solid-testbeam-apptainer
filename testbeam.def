Bootstrap: localimage
From: base.sif 

%arguments
	DEF_HASH=""

%setup

%files 
	./analyzer.sh /opt/analyzer.sh
	./SBS-offline.sh /opt/SBS-offline.sh
	./panguin.sh /opt/panguin.sh
%post
	microdnf update -y
	bash /opt/analyzer.sh
	bash /opt/panguin.sh
	bash /opt/SBS-offline.sh
	
	NOW=`date`
	
	rm /opt/analyzer.sh /opt/SBS-offline.sh
	echo "ANALYZER_HASH $(git -C /opt/analyzer-src rev-parse --short HEAD)" >> $APPTAINER_LABELS
	echo "REPLAY_HASH $(git -C /opt/SBS-replay_SOLIDtestbeam rev-parse --short HEAD)" >> $APPTAINER_LABELS
	echo "SBS-OFFLINE_HASH $(git -C /opt/SBS-offline_SOLIDtestbeam-src rev-parse --short HEAD)" >> $APPTAINER_LABELS
	echo "PANGUIN_HASH $(git -C /opt/panguin rev-parse --short HEAD)" >> $APPTAINER_LABELS
	
%environment
	export ANALYZER=/opt/analyzer
	export PATH=/opt/panguin/bin:/opt/analyzer/bin:/opt/SBS-offline_SOLIDtestbeam/bin:$PATH
	export LD_LIBRARY_PATH=/opt/panguin/lib64:/opt/analyzer/lib64:/opt/SBS-offline_SOLIDtestbeam/lib64/:$LD_LIBRARY_PATH
	export ROOT_INCLUDE_PATH=/opt/SBS-offline_SOLIDtestbeam/include:/opt/analyzer/include:$ROOT_INCLUDE_PATH
	export SBS=/opt/SBS-offline_SOLIDtestbeam
	export SBSOFFLINE=/opt/SBS-offline_SOLIDtestbeam
	export SBS_REPLAY=/opt/SBS-replay_SOLIDtestbeam
	export CMAKE_PREFIX_PATH="$ANALYZER${CMAKE_PREFIX_PATH:+:$CMAKE_PREFIX_PATH}"
	export PANGUIN_CONFIG_PATH=/opt/SBS-replay_SOLIDtestbeam/onlineGUIconfig:/opt/SBS-replay_SOLIDtestbeam/onlineGUIconfig/scripts
	
	export DB_DIR=/opt/SBS-replay_SOLIDtestbeam/DB
	export OUT_DIR=/opt/Rootfiles
	export DATA_DIR=/opt/data
	export LOG_DIR=/opt/logs
%runscript
	analyzer  "$@"

%test 
	analyzer -v
	if [ $? -eq 0 ]; then
        	echo "analyzer is running sucessfully."
	else
        	echo "Build failed."
        	exit 1
    	fi
%labels
	DEF_HASH {{ DEF_HASH }}
